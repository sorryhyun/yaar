{
  "name": "@yaar/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "YAAR TypeScript backend with Claude Agent SDK",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "bun src/main.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@modelcontextprotocol/sdk": "1.25.3",
    "@yaar/compiler": "workspace:*",
    "@yaar/shared": "workspace:*",
    "node-poppler": "^9.1.1",
    "qrcode-terminal": "^0.12.0",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "^1.3.11",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "bun": ">=1.1.22"
  }
}
