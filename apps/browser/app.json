{
  "icon": "🌐",
  "name": "Browser",
  "description": "Live browser with SSE screenshot streaming and navigation controls",
  "run": "static/index.html",
  "createShortcut": false,
  "appProtocol": true,
  "protocol": {
    "state": {
      "currentUrl": {
        "description": "Currently displayed URL"
      }
    },
    "commands": {
      "refresh": {
        "description": "Refresh screenshot and optionally update URL bar. Params: { url?, title? }",
        "params": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          }
        }
      },
      "clear": {
        "description": "Clear the browser display. Params: {}",
        "params": {
          "type": "object",
          "properties": {}
        }
      },
      "navigate": {
        "description": "Navigate the browser to a URL. Params: { url }",
        "params": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            }
          },
          "required": ["url"]
        }
      }
    }
  },
  "capture": "dom"
}
