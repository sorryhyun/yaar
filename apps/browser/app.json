{
  "icon": "🎮",
  "name": "Browser",
  "description": "Visible browser automation tool showing live screenshots from Playwright sessions.",
  "run": "static/index.html",
  "createShortcut": false,
  "appProtocol": true,
  "protocol": {
    "state": {
      "currentUrl": {
        "description": "Currently displayed URL"
      }
    },
    "commands": {
      "refresh": {
        "description": "Refresh screenshot and optionally update URL bar",
        "params": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          }
        }
      },
      "clear": {
        "description": "Clear the browser display",
        "params": {
          "type": "object",
          "properties": {}
        }
      },
      "navigate": {
        "description": "Navigate the browser to a URL",
        "params": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            }
          },
          "required": ["url"]
        }
      }
    }
  }
}
