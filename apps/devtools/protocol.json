{
  "state": {
    "project": {
      "description": "Active project"
    },
    "projects": {
      "description": "All projects"
    },
    "openFile": {
      "description": "Currently open file (with line numbers)"
    },
    "diagnostics": {
      "description": "TypeScript errors/warnings"
    },
    "compileStatus": {
      "description": "Compilation state"
    },
    "compileErrors": {
      "description": "Compilation errors (if any)"
    },
    "previewUrl": {
      "description": "URL of last successful compilation"
    },
    "bundledLibraries": {
      "description": "Available @bundled/* import libraries"
    },
    "consoleLogs": {
      "description": "Console output from preview app"
    }
  },
  "commands": {
    "createProject": {
      "description": "Create a new project",
      "params": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "openProject": {
      "description": "Switch to an existing project",
      "params": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "deleteProject": {
      "description": "Delete a project",
      "params": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    },
    "openFile": {
      "description": "Open a file (or multiple files) in the editor. Use `path` for a single file or `files` array for multiple files.",
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Single file path"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Multiple file paths to open as tabs"
          }
        }
      }
    },
    "readFile": {
      "description": "Read one or more files and return their contents with line numbers. Does NOT change the editor open state. ",
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "oneOf": [
              {
                "type": "string",
                "description": "Single file path"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Multiple file paths"
              }
            ]
          },
          "startLine": {
            "type": "number",
            "description": "Start line (1-based, inclusive)"
          },
          "endLine": {
            "type": "number",
            "description": "End line (1-based, inclusive)"
          },
          "openInEditor": {
            "type": "boolean",
            "description": "Also open file(s) in editor UI"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    "writeFile": {
      "description": "Write content to a file",
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "content"
        ]
      }
    },
    "editFile": {
      "description": "Edit a file (search & replace)",
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "search": {
            "type": "string",
            "description": "Text to find (alias: oldString)"
          },
          "replace": {
            "type": "string",
            "description": "Replacement text (alias: newString)"
          }
        },
        "required": [
          "path",
          "search",
          "replace"
        ]
      }
    },
    "deleteFile": {
      "description": "Delete a file",
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    "copyFile": {
      "description": "Copy a file to another path within the active project. ",
      "params": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "Source file path (e.g. \"src/Foo.ts\")"
          },
          "to": {
            "type": "string",
            "description": "Destination file path (e.g. \"src/ui/Foo.ts\")"
          }
        },
        "required": [
          "from",
          "to"
        ]
      }
    },
    "grep": {
      "description": "Search file contents with regex across the project",
      "params": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Regex pattern to search for"
          },
          "glob": {
            "type": "string",
            "description": "File glob filter (e.g. \"src/**/*.ts\")"
          }
        },
        "required": [
          "pattern"
        ]
      }
    },
    "compile": {
      "description": "Compile the active project",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "typecheck": {
      "description": "Run TypeScript type checker",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "deploy": {
      "description": "Deploy to apps/",
      "params": {
        "type": "object",
        "properties": {
          "appId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "appId"
        ]
      }
    },
    "preview": {
      "description": "Open preview window for the compiled app",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "viewPreview": {
      "description": "Read the current preview window state (content, size, position)",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "previewQuery": {
      "description": "Query app protocol state from the preview window",
      "params": {
        "type": "object",
        "properties": {
          "stateKey": {
            "type": "string",
            "description": "State key to query"
          }
        },
        "required": [
          "stateKey"
        ]
      }
    },
    "previewCommand": {
      "description": "Send an app protocol command to the preview window",
      "params": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Command name"
          },
          "params": {
            "type": "object",
            "description": "Command parameters"
          }
        },
        "required": [
          "command"
        ]
      }
    },
    "describeUri": {
      "description": "Describe a yaar:// URI — returns supported verbs, description, and invoke schema",
      "params": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "yaar:// URI to describe (e.g. \"yaar://sessions/\")"
          }
        },
        "required": [
          "uri"
        ]
      }
    },
    "listUri": {
      "description": "List child resources under a yaar:// URI",
      "params": {
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "description": "yaar:// URI to list (e.g. \"yaar://sessions/\")"
          }
        },
        "required": [
          "uri"
        ]
      }
    },
    "cloneApp": {
      "description": "Clone an installed app source into a new project",
      "params": {
        "type": "object",
        "properties": {
          "appId": {
            "type": "string",
            "description": "App ID to clone"
          }
        },
        "required": [
          "appId"
        ]
      }
    },
    "describeBundledLibrary": {
      "description": "Get detailed type information (methods, interfaces) for a @bundled/* library",
      "params": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Library name (e.g. \"yaar\", \"anime\", \"three\")"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "clearConsole": {
      "description": "Clear console output",
      "params": {
        "type": "object",
        "properties": {}
      }
    }
  }
}
