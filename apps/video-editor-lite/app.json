{
  "icon": "🎬",
  "name": "Video Editor Lite",
  "description": "Trim and preview videos with in-browser export for selected ranges.",
  "run": "static/index.html",
  "appProtocol": true,
  "protocol": {
    "state": {
      "currentSource": {
        "description": "Current media source information."
      },
      "playbackState": {
        "description": "Playback status including play/pause, loop preview, and rate."
      },
      "timeline": {
        "description": "Current playback time and total duration in seconds."
      },
      "trimRange": {
        "description": "Current trim in/out range and selected duration in seconds."
      }
    },
    "commands": {
      "loadSource": {
        "description": "Load a media source by direct URL or storage path.",
        "params": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "path": {
              "type": "string",
              "description": "Path under /api/storage/."
            }
          },
          "additionalProperties": false
        }
      },
      "play": {
        "description": "Start playback.",
        "params": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      "pause": {
        "description": "Pause playback.",
        "params": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      },
      "seek": {
        "description": "Seek to an absolute playback time in seconds.",
        "params": {
          "type": "object",
          "properties": {
            "time": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": ["time"],
          "additionalProperties": false
        }
      },
      "setPlaybackRate": {
        "description": "Set playback speed. Allowed values: 0.5, 1, 1.5, 2.",
        "params": {
          "type": "object",
          "properties": {
            "rate": {
              "type": "number",
              "enum": [0.5, 1, 1.5, 2]
            }
          },
          "required": ["rate"],
          "additionalProperties": false
        }
      }
    }
  }
}
