{
  "hooks": [
    {
      "id": "hook-1",
      "event": "tool_use",
      "filter": {
        "verb": "invoke",
        "uri": "yaar://apps/*",
        "action": "clone"
      },
      "action": {
        "type": "os_action",
        "payload": {
          "type": "toast.show",
          "id": "dev-clone",
          "message": "Cloning project...",
          "variant": "info"
        }
      },
      "label": "Toast on app clone",
      "enabled": true,
      "createdAt": "2025-01-01T00:00:00.000Z"
    },
    {
      "id": "hook-2",
      "event": "tool_use",
      "filter": {
        "verb": "invoke",
        "uri": "yaar://apps/*",
        "action": ["write", "edit"]
      },
      "action": {
        "type": "os_action",
        "payload": {
          "type": "toast.show",
          "id": "dev-write",
          "message": "Writing source files...",
          "variant": "info"
        }
      },
      "label": "Toast on app write",
      "enabled": true,
      "createdAt": "2025-01-01T00:00:00.000Z"
    },
    {
      "id": "hook-5",
      "event": "tool_use",
      "filter": {
        "verb": "invoke",
        "uri": "yaar://windows/*",
        "action": "app_command"
      },
      "action": {
        "type": "os_action",
        "payload": {
          "type": "toast.show",
          "id": "window-app-cmd",
          "message": "Sending command to app...",
          "variant": "info"
        }
      },
      "label": "Toast on monitor→app command via verb",
      "enabled": true,
      "createdAt": "2026-04-02T00:00:00.000Z"
    },
    {
      "id": "hook-8",
      "event": "launch",
      "action": {
        "type": "os_action",
        "payload": {
          "type": "window.create",
          "windowId": "dock",
          "title": "Dock",
          "bounds": {
            "y": 0,
            "w": 180,
            "h": 96
          },
          "content": {
            "renderer": "iframe",
            "data": "/api/apps/dock/dist/index.html"
          },
          "frameless": true,
          "windowStyle": {
            "position": "fixed",
            "top": 0,
            "right": 0,
            "left": "auto"
          }
        }
      },
      "label": "Open Dock on startup",
      "enabled": true,
      "createdAt": "2026-03-20T07:04:13.624Z"
    }
  ],
  "idCounter": 8
}
