{
  "name": "yaar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reactive AI interface where the AI decides what to show and do next",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:server": "bun run --filter @yaar/server dev",
    "dev:frontend": "bun run --filter @yaar/frontend dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "test:frontend": "bun run --filter @yaar/frontend test",
    "test:server": "bun run --filter @yaar/server test",
    "test:shared": "bun run --filter @yaar/shared test",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules dist",
    "build:exe": "bun run build:exe:prepare && bun run build:exe:libs && bun run build:exe:bundle",
    "build:exe:prepare": "bun run --filter '*' build",
    "build:exe:libs": "bun scripts/prebundle-libs.js",
    "build:exe:bundle": "bun scripts/build-exe-bundle.js --target windows",
    "build:exe:bundle:linux": "bun scripts/build-exe-bundle.js --target linux",
    "build:exe:bundle:macos": "bun scripts/build-exe-bundle.js --target macos",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,js,jsx}\" \"*.json\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,js,jsx}\" \"*.json\"",
    "prepare": "husky"
  },
  "engines": {
    "bun": ">=1.1.22"
  },
  "trustedDependencies": [
    "canvas"
  ],
  "lint-staged": {
    "packages/server/src/**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/frontend/src/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/shared/src/**/*.{ts,js}": [
      "prettier --write"
    ],
    "packages/compiler/src/**/*.{ts,js}": [
      "prettier --write"
    ],
    "*.{json,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@e965/xlsx": "*",
    "@types/bun": "^1.3.11",
    "animejs": "*",
    "cannon-es": "*",
    "chart.js": "*",
    "clsx": "*",
    "d3": "*",
    "date-fns": "*",
    "diff": "*",
    "diff2html": "*",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "konva": "*",
    "lint-staged": "^16.2.7",
    "lodash-es": "*",
    "mammoth": "*",
    "marked": "*",
    "matter-js": "*",
    "node-poppler-win32": "1.0.2",
    "p5": "*",
    "pixi.js": "*",
    "prettier": "^3.8.1",
    "prismjs": "*",
    "solid-js": "*",
    "three": "*",
    "tone": "*",
    "uuid": "*"
  },
  "dependencies": {
    "typescript": "^6.0.2"
  }
}
